<?xml version="1.0" encoding="UTF-8" ?>
<class name="AbilitySystemAttributeSet" inherits="Resource" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../doc/class.xsd">
	<brief_description>
		Resource managing a collection of attributes and starting abilities.
	</brief_description>
	<description>
		[AbilitySystemAttributeSet] defines which attributes an actor has and which abilities are granted by default.
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="add_attribute_definition">
			<return type="void" />
			<param index="0" name="attribute" type="AbilitySystemAttribute" />
			<description>
				Adds an attribute definition to the set.
			</description>
		</method>
		<method name="add_modifier">
			<return type="void" />
			<param index="0" name="name" type="StringName" />
			<param index="1" name="value" type="float" />
			<param index="2" name="type" type="int" enum="AbilitySystemAttributeSet.ModifierType" default="MODIFIER_ADD" />
			<description>
			</description>
		</method>
		<method name="get_attribute_base_value" qualifiers="const">
			<return type="float" />
			<param index="0" name="name" type="StringName" />
			<description>
				Returns the base value of the specified attribute.
			</description>
		</method>
		<method name="get_attribute_current_value" qualifiers="const">
			<return type="float" />
			<param index="0" name="name" type="StringName" />
			<description>
				Returns the modified value.
			</description>
		</method>
		<method name="get_attribute_definition" qualifiers="const">
			<return type="AbilitySystemAttribute" />
			<param index="0" name="name" type="StringName" />
			<description>
				Returns the definition of the specified attribute.
			</description>
		</method>
		<method name="get_attribute_list" qualifiers="const">
			<return type="StringName[]" />
			<description>
				Returns a list of all attribute names in the set.
			</description>
		</method>
		<method name="get_attribute_value" qualifiers="const">
			<return type="float" />
			<param index="0" name="name" type="StringName" />
			<description>
			</description>
		</method>
		<method name="has_attribute" qualifiers="const">
			<return type="bool" />
			<param index="0" name="name" type="StringName" />
			<description>
				Returns true if the set contains the specified attribute.
			</description>
		</method>
		<method name="remove_attribute_definition">
			<return type="void" />
			<param index="0" name="name" type="StringName" />
			<description>
				Removes an attribute definition from the set by its tag name.
			</description>
		</method>
		<method name="remove_modifier">
			<return type="void" />
			<param index="0" name="name" type="StringName" />
			<param index="1" name="value" type="float" />
			<param index="2" name="type" type="int" enum="AbilitySystemAttributeSet.ModifierType" default="MODIFIER_ADD" />
			<description>
			</description>
		</method>
		<method name="reset_current_values">
			<return type="void" />
			<description>
				Resets current values to base values.
			</description>
		</method>
		<method name="set_attribute_base_value">
			<return type="void" />
			<param index="0" name="name" type="StringName" />
			<param index="1" name="value" type="float" />
			<description>
				Sets the base value for a specific attribute.
			</description>
		</method>
		<method name="set_attribute_current_value">
			<return type="void" />
			<param index="0" name="name" type="StringName" />
			<param index="1" name="value" type="float" />
			<description>
				Sets the current (modified) value for a specific attribute.
			</description>
		</method>
	</methods>
	<members>
		<member name="attribute_definitions" type="AbilitySystemAttribute[]" setter="set_attribute_definitions" getter="get_attribute_definitions" default="[]">
			Definitions for each attribute (limits, base).
		</member>
		<member name="granted_abilities" type="AbilitySystemAbility[]" setter="set_granted_abilities" getter="get_granted_abilities" default="[]">
			Abilities automatically given to the actor.
		</member>
	</members>
	<signals>
		<signal name="attribute_changed">
			<param index="0" name="attribute_name" type="StringName" />
			<param index="1" name="old_value" type="float" />
			<param index="2" name="new_value" type="float" />
			<description>
				Emitted when a value changes.
			</description>
		</signal>
		<signal name="attribute_pre_change">
			<param index="0" name="attribute_name" type="StringName" />
			<param index="1" name="old_value" type="float" />
			<param index="2" name="new_value" type="float" />
			<description>
				Emitted before an attribute value is changed, allowing for validation or modification of the incoming value.
			</description>
		</signal>
	</signals>
	<constants>
		<constant name="MODIFIER_ADD" value="0" enum="ModifierType">
		</constant>
		<constant name="MODIFIER_MULTIPLY" value="1" enum="ModifierType">
		</constant>
	</constants>
</class>
