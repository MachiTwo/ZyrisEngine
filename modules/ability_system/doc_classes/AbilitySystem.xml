<?xml version="1.0" encoding="UTF-8" ?>
<class name="AbilitySystem" inherits="Object" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../doc/class.xsd">
	<brief_description>
		Central authority for Tags.
	</brief_description>
	<description>
		[AbilitySystem] is a singleton that manages the global registry of Tags for the project.
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="get_registered_tags" qualifiers="const">
			<return type="StringName[]" />
			<description>
				Returns all tags registered in the system.
			</description>
		</method>
		<method name="get_resource_name_owner" qualifiers="const">
			<return type="int" />
			<param index="0" name="name" type="String" />
			<description>
				Returns the instance ID of the resource that owns the given name.
			</description>
		</method>
		<method name="is_tag_registered" qualifiers="const">
			<return type="bool" />
			<param index="0" name="tag" type="StringName" />
			<description>
				Checks if a tag is registered.
			</description>
		</method>
		<method name="register_resource_name">
			<return type="bool" />
			<param index="0" name="name" type="String" />
			<param index="1" name="owner_id" type="int" />
			<description>
				Registers a unique name for a resource.
			</description>
		</method>
		<method name="register_tag">
			<return type="void" />
			<param index="0" name="tag" type="StringName" />
			<param index="1" name="owner_id" type="int" default="0" />
			<description>
				Registers a new tag globally.
			</description>
		</method>
		<method name="tag_matches" qualifiers="static">
			<return type="bool" />
			<param index="0" name="tag" type="StringName" />
			<param index="1" name="match_against" type="StringName" />
			<param index="2" name="exact" type="bool" default="false" />
			<description>
				Utility for hierarchical tag matching.
			</description>
		</method>
		<method name="unregister_resource_name">
			<return type="void" />
			<param index="0" name="name" type="String" />
			<description>
				Unregisters a resource name.
			</description>
		</method>
		<method name="unregister_tag">
			<return type="void" />
			<param index="0" name="tag" type="StringName" />
			<description>
				Unregisters a tag.
			</description>
		</method>
	</methods>
	<signals>
		<signal name="tags_changed">
			<description>
				Emitted when the registered tags are changed.
			</description>
		</signal>
	</signals>
</class>
